# IT Management — keep UTF-8 and predictable line endings for agents and Laragon on Windows.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
charset = utf-8

[*.php]
charset = utf-8

[*.sql]
charset = utf-8

[*.js]
charset = utf-8

[*.css]
charset = utf-8

[*.html]
charset = utf-8
