# Copy to `.env` in the project root (same folder as `config/`).
# Loaded on startup by `config/config.php` when present.
# Drift audit: php scripts/check_env_vars_in_use.php

# --- Database (config/config.php) ---
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

# --- Deployment / security (config/config.php) ---
# Canonical public base URL — avoids Host-header poisoning. Example: https://itm.example.com/app/
ITM_APP_URL=
# Comma-separated allowed Host values when ITM_APP_URL is empty (reverse-proxy / multi-host).
ITM_ALLOWED_HOSTS=
# Optional maintenance bypass token (see config/config.php).
ITM_MAINTENANCE_TOKEN=
# Set to 1 to disable System Status tenant cache fallback (admin module).
SYSTEM_STATUS_DISABLE_TENANT_FALLBACK=0

# --- IP2WHOIS — hosted domains by IP (IP Subnets → Search) ---
# Register: https://www.ip2whois.com/register
IP2WHOIS_API_KEY=
# Optional alias (same effect as IP2WHOIS_API_KEY):
# ITM_IP2WHOIS_API_KEY=

# --- NVD CVE API (News module → CVE (NVD) source; optional — higher rate limits) ---
# Request a key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# Optional alias (same effect as NVD_API_KEY):
# ITM_NVD_API_KEY=

# --- Resend — fallback when no tenant SMTP profile (includes/itm_email.php) ---
# https://resend.com/
RESEND_API_KEY=
