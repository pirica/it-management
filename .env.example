# Copy to `.env` in the project root (same folder as `config/`).
# `.env` is read on startup by `config/config.php` when present.

DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=




# IP2WHOIS — hosted domains by IP (Network Discovery on IP Subnets → Search).
# Get a key: https://www.ip2whois.com/register
# API: GET https://domains.ip2whois.com/domains?ip={ip}&key={key}
IP2WHOIS_API_KEY=

# Optional alias (same effect as IP2WHOIS_API_KEY):
# ITM_IP2WHOIS_API_KEY=


# Resend API Configuration https://resend.com/
RESEND_API_KEY=re_xxxxxxxxx

# Email Configuration
EMAIL_FROM="Acme <onboarding@yourdomain.com>"
CONTACT_EMAIL=team@yourdomain.com

# Webhook Secret (for inbound emails)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Audience ID (for contacts management)
RESEND_AUDIENCE_ID=aud_xxxxxxxxx

# Template ID (for template examples)
RESEND_TEMPLATE_ID=tpl_xxxxxxxxx

# Redirect URL for double opt-in confirmation
CONFIRM_REDIRECT_URL=https://example.com/confirmed
