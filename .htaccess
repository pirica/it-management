# Disable directory listing
Options -Indexes

# Prioritize PHP
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /it-management/

    # Allow ONLY the root folder to load normally
    RewriteCond %{REQUEST_URI} ^/it-management/?$
    RewriteRule ^ - [L]

    # Block direct access to ANY other folder
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [F]
</IfModule>

